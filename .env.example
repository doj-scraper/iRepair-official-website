VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Use a local .env file for your Neon connection string.
# Example:
# DATABASE_URL="postgresql://<username>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DATABASE_URL_DIRECT="postgresql://<username>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
# DIRECT_URL="postgresql://<username>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
# STRIPE_SECRET_KEY="sk_live_..."
DATABASE_URL="postgresql://<username>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
